# ========================================
# 开发环境配置
# ========================================
# 
# 数据存储模式选择:
# - true: 使用浏览器 localStorage（无需后端，数据在浏览器中）
# - false: 使用后端API（需启动后端，数据在本地H2数据库文件中）
#
# localStorage模式：数据存储在浏览器中，清除浏览器数据会丢失
# 后端API模式：数据存储在 backend/data/suziblog.mv.db 文件中，持久化保存
#
REACT_APP_USE_LOCAL_STORAGE=false
REACT_APP_API_BASE_URL=http://localhost:8080/api
